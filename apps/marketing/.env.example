# Waitlist storage (Phase 1). Without these, the waitlist falls back to a local
# data/waitlist.json file so the flow still works in development.
#
# Create a Supabase project, add a `waitlist` table (see lib/waitlist.ts for the
# schema), then set:
SUPABASE_URL=
# Server-only key used by the /app server action to insert rows. Use a Supabase
# SECRET API key (sb_secret_...), which bypasses RLS. Server-only — never expose
# it to the client (do NOT prefix with NEXT_PUBLIC_).
SUPABASE_SECRET_KEY=
# Legacy fallback (older projects): SUPABASE_SERVICE_ROLE_KEY=

# Feature flags (F-5) — default true; set to "false" to hide.
# NEXT_PUBLIC_SHOW_ANNOUNCEMENT=true
# NEXT_PUBLIC_WAITLIST_OPEN=true
