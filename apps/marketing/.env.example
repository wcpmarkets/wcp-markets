# Waitlist storage (Phase 1). Without these, the waitlist falls back to a local
# data/waitlist.json file so the flow still works in development.
#
# Create a Supabase project, add a `waitlist` table (see lib/waitlist.ts for the
# schema), then set:
SUPABASE_URL=
# Server-only key used by the /app server action to insert rows. Use a Supabase
# SECRET API key (sb_secret_...), which bypasses RLS. Server-only — never expose
# it to the client (do NOT prefix with NEXT_PUBLIC_).
SUPABASE_SECRET_KEY=
# Legacy fallback (older projects): SUPABASE_SERVICE_ROLE_KEY=

# Waitlist confirmation email (double opt-in) — Resend. Without RESEND_API_KEY the
# confirmation email is skipped (the signup is still saved). Get the key from
# resend.com; the FROM domain must be verified there (DKIM/SPF DNS records).
RESEND_API_KEY=
# RESEND_FROM="WCP Markets <hello@wcpmarkets.com>"
# Base URL used to build the confirm link in the email.
# SITE_URL=https://www.wcpmarkets.com

# Analytics (F-7) — PostHog. Public (client-side) project key; safe to expose.
# Without it, track() just logs to the console. Get the key from your PostHog
# project settings; set the host to us/eu to match where you created the project.
NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Feature flags (F-5) — default true; set to "false" to hide.
# NEXT_PUBLIC_SHOW_ANNOUNCEMENT=true
# NEXT_PUBLIC_WAITLIST_OPEN=true
