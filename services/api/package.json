{
  "name": "@wcp/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/app.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "gen:openapi": "tsx scripts/emit-openapi.ts",
    "gen:deal-guard": "tsx scripts/gen-deal-guard.ts",
    "build:lambda": "esbuild src/lambda.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/lambda.mjs --external:@aws-sdk/*",
    "build:sweeper": "esbuild src/sweeper.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/sweeper.mjs --external:@aws-sdk/*",
    "build:consumer": "esbuild src/consumer.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/consumer.mjs --external:@aws-sdk/*",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-openapi": "^0.18.3",
    "@wcp/escrow": "workspace:*",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@aws-sdk/client-ssm": "^3.700.0",
    "@aws-sdk/client-sqs": "^3.700.0",
    "@types/node": "^22.10.7",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
